rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Fountain rules
    match /fountains/{fountainId} {
      // Anyone can read fountain data
      allow read: if true;
      
      // Only authenticated users can create fountains
      allow create: if request.auth != null;
      
      // Only the creator can update their own fountains
      allow update: if request.auth != null && 
        request.auth.uid == resource.data.addedBy;
      
      // Only the creator can delete their own fountains
      allow delete: if request.auth != null && 
        request.auth.uid == resource.data.addedBy;
    }
  }
}
